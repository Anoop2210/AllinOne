PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_core
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_to_a_long_random_secret_too
JWT_REFRESH_EXPIRES_IN=7d

# Super Admin bootstrap (created on first run if no super admin exists)
SUPER_ADMIN_EMAIL=superadmin@crmcore.com
SUPER_ADMIN_PASSWORD=ChangeMe@123
#rezorpay#
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
#meta#
META_WEBHOOK_VERIFY_TOKEN=crm-core-verify